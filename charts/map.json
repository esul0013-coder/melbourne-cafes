{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Cafe density across inner Melbourne suburbs",
    "color": "#FAF6EE",
    "fontSize": 14,
    "font": "Lato",
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 520,
  "background": "transparent",
  "params": [
    {
      "name": "year_selection",
      "value": 2024,
      "bind": {
        "input": "range",
        "min": 2002,
        "max": 2024,
        "step": 1,
        "name": "Select year: "
      }
    }
  ],
  "config": {
    "font": "Lato",
    "legend": {
      "labelFont": "Lato",
      "titleFont": "Lato",
      "labelFontSize": 12,
      "titleFontSize": 12,
      "titleColor": "#3E1F00",
      "labelColor": "#3E1F00"
    },
    "view": {
      "stroke": null
    },
    "title": {
      "color": "#FAF6EE",
      "fontSize": 14
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/cafes_by_area_year.csv"
      },
      "transform": [
        {
          "filter": "datum.year == toString(year_selection)"
        },
        {
          "filter": "datum.area != 'West Melbourne (Industrial)'"
        },
        {
          "lookup": "area",
          "from": {
            "data": {
              "url": "data/suburbs.geojson",
              "format": {
                "type": "json",
                "property": "features"
              }
            },
            "key": "properties.featurenam",
            "fields": [
              "geometry"
            ]
          },
          "as": "geo"
        }
      ],
      "projection": {
        "type": "mercator"
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#F5A623",
        "strokeWidth": 2
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
          "field": "cafe_count",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [
              20,
              60,
              150
            ],
            "range": [
              "#F5ECD7",
              "#D4A96A",
              "#C8843A",
              "#3E1F00"
            ]
          },
          "legend": {
            "title": "Number of cafes",
            "orient": "top-left",
            "gradientLength": 140,
            "gradientThickness": 12,
            "offset": 8,
            "labelColor": "#FAF6EE",
            "titleColor": "#FAF6EE",
            "labelFontSize": 12,
            "titleFontSize": 12
          }
        },
        "tooltip": [
          {
            "field": "area",
            "type": "nominal",
            "title": "Suburb"
          },
          {
            "field": "cafe_count",
            "type": "quantitative",
            "title": "Cafes"
          },
          {
            "field": "total_seats",
            "type": "quantitative",
            "title": "Total seats"
          },
          {
            "field": "year",
            "type": "ordinal",
            "title": "Year"
          }
        ]
      }
    },
    {
      "data": {
        "url": "data/suburb_centroids.csv"
      },
      "projection": {
        "type": "mercator"
      },
      "mark": {
        "type": "text",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#4f4949"
      },
      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "area",
          "type": "nominal"
        }
      }
    }
  ]
}